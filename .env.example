# AI API Key Configuration / AI API Key 配置
# Copy this file to .env and fill in your values / 复制此文件为 .env 并填写你的配置

# Built-in API Key (demo mode if empty) / 内置 API Key（留空则使用演示模式）
AI_API_KEY=sk-your-openai-key

# Model name / 模型名称
AI_MODEL=gpt-4o-mini

# API base URL (OpenAI compatible) / API 基础地址（OpenAI 兼容）
AI_BASE_URL=https://api.openai.com/v1

# Server port / 服务器端口
PORT=3001
